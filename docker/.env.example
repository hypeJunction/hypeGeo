# Per-plugin docker test environment.
# Copy this file to docker/.env and fill in PLUGIN_ID.

# Lowercase Elgg plugin id. Must match the plugin directory name and the
# "name" field in composer.json (Elgg 4+). Example: my_plugin
PLUGIN_ID=

# Optional: override host-side ports if the defaults clash with another stack.
# ELGG_PORT=8480
# DB_PORT=3304
