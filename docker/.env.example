# Copy to .env and adjust. The compose file refuses to start without
# ELGG_PORT and DB_PORT set (no defaults) so that parallel migrations
# and validation runs never collide on the same host port.
#
# Pick any free ports. The orchestrator (bin/elgg-migrate-run) writes
# a per-job .env automatically; this file is for ad-hoc manual runs.
ELGG_PORT=8300
DB_PORT=13300
