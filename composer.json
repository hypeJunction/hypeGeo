{
	"name": "hypejunction/hypegeo",
	"type": "elgg-plugin",
	"repository": "hypeJunction/hypeGeo",
	"description": "Tools for building geo-aware plugins for Elgg",
	"homepage": "http://hypejunction.com",
	"minimum-stability": "stable",
	"keywords": [
		"elgg",
		"plugin",
		"geography",
		"geocoding"
	],
	"license": "GPL-2.0",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"extra": {
		"installer-name": "hypeGeo"
	},
	"config": {
		"vendor-dir": "vendors",
		"preferred-install": "dist"
	},
	"require": {
		"composer/installers": "^1.0 || ^2.0",
		"php": ">=7.2",
		"elgg/elgg": "^3.0",
		"willdurand/geocoder": "@stable",
		"treffynnon/navigator": "1.0.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	}
}
